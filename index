<script>
// ── DATA ──
const CHANNELS = ['Web Sitesi', 'Mobil Uygulama', 'SMS', 'Çağrı Merkezi', 'Banka Transferi', 'Elden Teslim'];
const PAYMENT_METHODS = ['Kredi Kartı', 'Banka Transferi / EFT', 'Kapıda Nakit', 'Mobil Ödeme', 'FAST'];
const CAMPAIGNS = ['Deprem Yardım Kampanyası 2024', 'Kış Yardım Seferberliği', 'Sel Afeti Acil Yardım', 'Okul Çantası Kampanyası', 'Genel Bağış'];
const CURRENCIES = ['TRY', 'USD', 'EUR', 'GBP', 'SAR'];
const DONATION_TYPES = ['Düzenli Nakdi Bağış', 'Tek Seferlik Bağış'];
const DIST_RESULTS = ['Dağıtıldı', 'Beklemede', 'Hata', 'Kısmi Dağıtım', '—'];
const FIRST_NAMES = ['Ahmet','Mehmet','Ayşe','Fatma','Ali','Hasan','Zeynep','Merve','Murat','Emre','Selin','Leyla','Yusuf','Ömer','Elif'];
const LAST_NAMES = ['Yılmaz','Kaya','Demir','Çelik','Şahin','Yıldız','Arslan','Doğan','Aydın','Öztürk','Koç','Kurt','Polat','Aslan','Güneş'];

const IBANS = {
  'Deprem Yardım Kampanyası 2024': 'TR33 0006 1005 1978 6457 8413 26',
  'Kış Yardım Seferberliği':       'TR49 0006 2000 4390 0006 2957 75',
  'Sel Afeti Acil Yardım':         'TR72 0001 2009 4520 0058 0000 00',
  'Okul Çantası Kampanyası':       'TR82 0006 4000 0014 2630 4295 26',
  'Genel Bağış':                   'TR40 0001 0017 4538 7373 1000 00',
};

const NOTES = ['—','—','—','—','Acil yardım için','Depremzedeler için','Geçmiş olsun','Allah kabul etsin','—','Çocuklar için','Hayırlı olsun'];

function rnd(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
function pad(n, len=2) { return String(n).padStart(len,'0'); }

function genDate() {
  const d = new Date(2024, Math.floor(Math.random()*12), Math.floor(Math.random()*28)+1);
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(Math.floor(Math.random()*24))}:${pad(Math.floor(Math.random()*60))}`;
}

// generate 2847 records
let allData = [];
for(let i=1; i<=2847; i++){
  const isAnon = Math.random() < 0.11;
  const firstName = rnd(FIRST_NAMES);
  const lastName = rnd(LAST_NAMES);
  const campaign = rnd(CAMPAIGNS);
  const isSuccess = Math.random() < 0.945;
  const donationType = rnd(DONATION_TYPES);
  const prjCode = 'PRJ-' + String(Math.floor(Math.random()*500)+1000);
  const orderId = 'ORD-' + String(1000000 + i);
  const detailCode = 'BGS-' + new Date().getFullYear() + pad(Math.floor(Math.random()*12)+1) + pad(Math.floor(Math.random()*28)+1) + '-' + pad(i,4);
  const amount = (Math.random() * 9500 + 50).toFixed(2);
  const distResult = isSuccess ? rnd(['Dağıtıldı','Dağıtıldı','Dağıtıldı','Beklemede','Kısmi Dağıtım']) : 'Hata';
  allData.push({
    no: i, code: detailCode, orderId, projCode: prjCode, campaign,
    iban: IBANS[campaign],
    donorName: isAnon ? null : firstName + ' ' + lastName,
    amount: parseFloat(amount),
    currency: rnd(CURRENCIES),
    channel: rnd(CHANNELS),
    date: genDate(),
    type: donationType,
    note: rnd(NOTES),
    isAnon,
    payMethod: rnd(PAYMENT_METHODS),
    status: isSuccess ? 'Başarılı' : 'Başarısız',
    distResult
  });
}

// ── STATE ──
let filteredData = [...allData];
let currentPage = 1;
let pageSize = 20;
let sortCol = -1;
let sortDir = 1;

// ── VIEW NAVIGATION ──
const viewMeta = {
  'view-bagis':      { label: 'Bağış Hareketleri Raporu', section: 'Raporlar' },
  'view-projects':   { label: 'Proje Yönetimi',           section: 'Kampanya Yönetimi' },
  'view-categories': { label: 'Kategori Yönetimi',        section: 'Kampanya Yönetimi' },
  'view-campaigns':  { label: 'Kampanya Yönetimi',        section: 'Kampanya Yönetimi' },
  'view-currencies': { label: 'Para Birimleri',           section: 'Bağış Yönetimi' },
  'view-menus':      { label: 'Menü Yönetimi',            section: 'İçerik Yönetimi' },
  'view-dashboard':  { label: 'Genel Bakış',              section: 'Ana Menü' },
};

function showView(viewId) {
  // hide all views
  document.querySelectorAll('.view-panel').forEach(v => v.style.display = 'none');
  // show target
  const target = document.getElementById(viewId);
  if (target) target.style.display = '';
  // update sidebar active
  document.querySelectorAll('.sidebar-item').forEach(a => a.classList.remove('active'));
  const clicked = document.querySelector(`[onclick="showView('${viewId}')"]`);
  if (clicked) clicked.classList.add('active');
  // update breadcrumb
  const meta = viewMeta[viewId] || { label: viewId, section: 'Yönetim Paneli' };
  const bc = document.getElementById('breadcrumb');
  if (bc) {
    bc.innerHTML = `
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
      Yönetim Paneli
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      ${meta.section}
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span>${meta.label}</span>`;
  }
}

// ── GENERIC TABLE FILTER ──
function filterGenericTable(tableId, query) {
  const q = query.toLowerCase();
  const rows = document.querySelectorAll(`#${tableId} tbody tr`);
  rows.forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

function filterGenericTableByCol(tableId, colIndex, value) {
  const rows = document.querySelectorAll(`#${tableId} tbody tr`);
  rows.forEach(row => {
    const cell = row.cells[colIndex];
    if (!cell) return;
    row.style.display = (!value || cell.textContent.trim() === value) ? '' : 'none';
  });
}


function renderTable() {
  const start = (currentPage - 1) * pageSize;
  const slice = filteredData.slice(start, start + pageSize);
  const tbody = document.getElementById('table-body');
  tbody.innerHTML = slice.map(r => `
    <tr>
      <td class="mono muted">${r.no}</td>
      <td class="mono" style="color:var(--primary);font-weight:600;">${r.code}</td>
      <td class="mono muted">${r.orderId}</td>
      <td class="mono muted">${r.projCode}</td>
      <td class="td-name">${r.campaign}</td>
      <td class="mono" style="font-size:11px;color:var(--text-muted);">${r.iban}</td>
      <td class="${r.isAnon ? 'td-anon' : 'td-name'}">${r.isAnon ? 'Anonim' : r.donorName}</td>
      <td style="font-weight:600;text-align:right;">${r.amount.toLocaleString('tr-TR',{minimumFractionDigits:2})}</td>
      <td><span class="badge badge-neutral">${r.currency}</span></td>
      <td>${r.channel}</td>
      <td class="mono muted" style="font-size:12px;">${r.date}</td>
      <td><span class="badge ${r.type==='Düzenli Nakdi Bağış'?'badge-info':'badge-neutral'}">${r.type}</span></td>
      <td class="muted">${r.note}</td>
      <td><span class="badge ${r.isAnon?'badge-warn':'badge-neutral'}">${r.isAnon?'Evet':'Hayır'}</span></td>
      <td>${r.payMethod}</td>
      <td><span class="badge ${r.status==='Başarılı'?'badge-success':'badge-fail'}">${r.status==='Başarılı'?'✓ ':r.status==='Başarısız'?'✗ ':''}${r.status}</span></td>
      <td><span class="badge ${r.distResult==='Dağıtıldı'?'badge-success':r.distResult==='Hata'?'badge-fail':r.distResult==='Beklemede'?'badge-warn':'badge-neutral'}">${r.distResult}</span></td>
    </tr>
  `).join('');
  renderPagination();
  document.getElementById('page-info').textContent =
    `${start+1}–${Math.min(start+pageSize, filteredData.length)} / ${filteredData.length.toLocaleString('tr-TR')} kayıt gösteriliyor`;
  document.getElementById('total-count').textContent = filteredData.length.toLocaleString('tr-TR');
}

function renderPagination() {
  const totalPages = Math.ceil(filteredData.length / pageSize);
  const ctrl = document.getElementById('pagination-controls');
  let html = '';
  html += `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;
  const pages = [];
  if(totalPages<=7){ for(let i=1;i<=totalPages;i++) pages.push(i); }
  else {
    pages.push(1);
    if(currentPage>3) pages.push('...');
    for(let i=Math.max(2,currentPage-1);i<=Math.min(totalPages-1,currentPage+1);i++) pages.push(i);
    if(currentPage<totalPages-2) pages.push('...');
    pages.push(totalPages);
  }
  pages.forEach(p => {
    if(p==='...') html += `<span style="padding:0 4px;color:var(--text-muted);">…</span>`;
    else html += `<button class="page-btn ${p===currentPage?'active':''}" onclick="goPage(${p})">${p}</button>`;
  });
  html += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===totalPages?'disabled':''}>›</button>`;
  ctrl.innerHTML = html;
}

function goPage(p) {
  const totalPages = Math.ceil(filteredData.length / pageSize);
  if(p<1||p>totalPages) return;
  currentPage = p;
  renderTable();
  document.querySelector('.page-content').scrollTop = document.querySelector('.page-content').scrollTop;
}

function changePageSize(v) { pageSize = parseInt(v); currentPage = 1; renderTable(); }

function sortTable(col) {
  if(sortCol===col) sortDir*=-1; else { sortCol=col; sortDir=1; }
  document.querySelectorAll('th').forEach((th,i)=>{
    th.classList.toggle('sorted', i===col);
    const si = th.querySelector('.sort-icon');
    if(si) si.textContent = i===col ? (sortDir===1?'↑':'↓') : '↕';
  });
  const keys = ['no','code','orderId','projCode','campaign','iban','donorName','amount','currency','channel','date','type','note','isAnon','payMethod','status','distResult'];
  const k = keys[col];
  filteredData.sort((a,b)=>{
    let va = a[k]??'', vb = b[k]??'';
    if(typeof va==='number') return sortDir*(va-vb);
    return sortDir * String(va).localeCompare(String(vb),'tr');
  });
  currentPage = 1;
  renderTable();
}

// ── FILTERS ──
function applyFilters() {
  const code = document.getElementById('f-code').value.trim().toLowerCase();
  const name = document.getElementById('f-name').value.trim().toLowerCase();
  const campaign = document.getElementById('f-campaign').value;
  const currency = document.getElementById('f-currency').value;
  const amtMin = parseFloat(document.getElementById('f-amount-min').value)||0;
  const amtMax = parseFloat(document.getElementById('f-amount-max').value)||Infinity;
  const type = document.getElementById('f-type').value;
  const status = document.getElementById('f-status').value;
  const noteFilter = document.getElementById('f-note').value.trim().toLowerCase();
  const dateStart = document.getElementById('f-date-start').value;
  const dateEnd = document.getElementById('f-date-end').value;

  filteredData = allData.filter(r => {
    if(code && !r.code.toLowerCase().includes(code)) return false;
    if(name){
      const dn = r.donorName?r.donorName.toLowerCase():'anonim';
      if(!dn.includes(name)) return false;
    }
    if(campaign && !r.campaign.startsWith(campaign.split('\u2013')[0].trim())) return false;
    if(currency && !r.currency.startsWith(currency.split('\u2013')[0].trim())) return false;
    if(r.amount < amtMin || r.amount > amtMax) return false;
    if(type && r.type !== type) return false;
    if(status && r.status !== status) return false;
    if(noteFilter && !r.note.toLowerCase().includes(noteFilter)) return false;
    if(dateStart && r.date < dateStart) return false;
    if(dateEnd && r.date > dateEnd+' 23:59') return false;
    return true;
  });

  currentPage = 1;
  renderTable();
  renderActiveTags();
  showToast(`${filteredData.length.toLocaleString('tr-TR')} kayıt listelendi`);
}

function resetFilters() {
  ['f-code','f-name','f-amount-min','f-amount-max','f-note','f-date-start','f-date-end'].forEach(id => document.getElementById(id).value='');
  ['f-campaign','f-currency','f-type','f-status'].forEach(id => document.getElementById(id).selectedIndex=0);
  filteredData = [...allData];
  currentPage = 1;
  renderTable();
  renderActiveTags();
}

function renderActiveTags() {
  const tags = [];
  const v = (id) => document.getElementById(id).value.trim();
  if(v('f-code')) tags.push({label:'Kod: '+v('f-code'), id:'f-code'});
  if(v('f-name')) tags.push({label:'İsim: '+v('f-name'), id:'f-name'});
  if(v('f-campaign')) tags.push({label:'Kampanya: '+v('f-campaign').split('–')[0].trim(), id:'f-campaign'});
  if(v('f-currency')) tags.push({label:'Para Birimi: '+v('f-currency').split('–')[0].trim(), id:'f-currency'});
  if(v('f-type')) tags.push({label:'Tür: '+v('f-type'), id:'f-type'});
  if(v('f-note')) tags.push({label:'Açıklama: '+v('f-note'), id:'f-note'});
  if(v('f-status')) tags.push({label:'Durum: '+v('f-status'), id:'f-status'});

  const cont = document.getElementById('active-tags');
  if(tags.length===0){ cont.style.display='none'; return; }
  cont.style.display='flex';
  cont.innerHTML = tags.map(t=>`<span class="filter-tag" onclick="clearTag('${t.id}')">
    ${t.label}
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </span>`).join('') +
  `<span class="filter-tag" onclick="resetFilters()" style="border-color:rgba(244,121,32,0.5);">
    Tümünü Temizle
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </span>`;
}

function clearTag(id) {
  const el = document.getElementById(id);
  if(el.tagName==='SELECT') el.selectedIndex=0; else el.value='';
  applyFilters();
}

// ── FILTER TOGGLE ──
let filterVisible = true;
function toggleFilter() {
  filterVisible = !filterVisible;
  const body = document.getElementById('filter-body');
  body.style.display = filterVisible ? 'grid' : 'none';
  document.getElementById('filter-toggle-label').textContent = filterVisible ? 'Gizle' : 'Göster';
  document.getElementById('filter-chevron').style.transform = filterVisible ? '' : 'rotate(-90deg)';
}

// ── THEME ──
function toggleTheme() {
  const html = document.documentElement;
  const isDark = html.getAttribute('data-theme')==='dark';
  html.setAttribute('data-theme', isDark?'light':'dark');
  const icon = document.getElementById('theme-icon');
  icon.innerHTML = isDark
    ? '<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>'
    : '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
}

// ── EXCEL EXPORT ──
function exportExcel() {
  const headers = ['Sıra No','Bağış Detay Kodu','Sipariş ID','Proje Kodu','Kampanya Adı','Kampanya IBAN','Bağışçı Adı Soyadı','Birim Tutar','Para Birimi','Bağış Kanalı','Bağış Tarihi','Bağış Türü','Bağışçı Notu','Anonim mi?','Ödeme Yöntemi','Ödeme Durumu','Dağıtım Talimat Sonucu'];
  const rows = filteredData.map(r=>[
    r.no, r.code, r.orderId, r.projCode, r.campaign, r.iban,
    r.isAnon?'Anonim':r.donorName, r.amount, r.currency, r.channel,
    r.date, r.type, r.note, r.isAnon?'Evet':'Hayır',
    r.payMethod, r.status, r.distResult
  ]);
  const csv = [headers,...rows].map(row=>row.map(c=>'"'+String(c??'').replace(/"/g,'""')+'"').join(',')).join('\n');
  const BOM = '\uFEFF';
  const blob = new Blob([BOM+csv],{type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href=url; a.download='bagis_hareketleri_raporu.csv'; a.click();
  URL.revokeObjectURL(url);
  showToast(`${filteredData.length.toLocaleString('tr-TR')} kayıt Excel'e aktarıldı`);
}

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 3000);
}

// ── INIT ──
renderTable();
</script>

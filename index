  </a>

  <div class="sidebar-section">Sistem</div>
  <a class="sidebar-item" href="#">
    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M4.93 19.07l1.41-1.41M21 12h-2M5 12H3M19.07 19.07l-1.41-1.41M4.93 4.93l1.41 1.41M12 21v-2M12 5V3"/></svg>
    Ayarlar
  </a>
</aside>

<!-- MAIN -->
<main class="main">
  <!-- HEADER -->
